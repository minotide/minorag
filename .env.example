# Configurações do minorag
# Copie este arquivo para .env e preencha os valores

# Porta do servidor web (padrão: 5000)
WEB_PORT=5000

# Repositório Git
GIT_REPO_URL=
GIT_BRANCH=main

# Atualizar codebase automaticamente no startup (true/false)
GIT_AUTO_UPDATE=false

# Token de acesso pessoal para repositórios privados (HTTPS)
# GitHub: Settings → Developer settings → Personal access tokens
GIT_ACCESS_TOKEN=

# Caminho para chave SSH privada (para URLs do tipo git@github.com:...)
GIT_SSH_KEY_PATH=
