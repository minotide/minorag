# Configurações do minorag
# Copie este arquivo para .env e preencha os valores

# ---------------------------------------------------------------------------
# Interface web
# ---------------------------------------------------------------------------

# Porta do servidor web (requer reinício do servidor para ter efeito)
WEB_PORT=5000

# ---------------------------------------------------------------------------
# Repositório Git (configurável pelo painel ⚙ Repositório)
# ---------------------------------------------------------------------------

GIT_REPO_URL=
GIT_BRANCH=main

# Atualizar codebase automaticamente no startup (true/false)
GIT_AUTO_UPDATE=false

# Token de acesso pessoal para repositórios privados (HTTPS)
# GitHub: Settings → Developer settings → Personal access tokens
GIT_ACCESS_TOKEN=

# Caminho para chave SSH privada (para URLs do tipo git@github.com:...)
GIT_SSH_KEY_PATH=

# ---------------------------------------------------------------------------
# LLM e Ollama (configurável pelo painel ⚙ LLM)
# ---------------------------------------------------------------------------

OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5-coder:3b

# Chunks mais relevantes enviados como contexto por pergunta
TOP_K=8

# Opções de inferência do Ollama
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=1024
OLLAMA_NUM_THREAD=8
OLLAMA_NUM_BATCH=512
OLLAMA_TEMPERATURE=0.2
OLLAMA_REPEAT_PENALTY=1.3

# Prompt template enviado ao LLM (newlines como \n)
# Use {chunks} e {question} como marcadores obrigatórios
# Deixe em branco para usar o padrão embutido
PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------
# Indexação de arquivos (configurável pelo painel ⚙ Indexação)
# ---------------------------------------------------------------------------

# Extensões indexadas (separadas por vírgula)
FILE_EXTENSIONS=.java,.py,.js,.ts,.go,.rs,.c,.cpp,.h,.cs,.rb,.php,.kt,.scala,.swift,.m,.sql,.sh

# Arquivos incluídos pelo nome exato (separados por vírgula)
INCLUDE_FILENAMES=architecture.md

# Diretórios ignorados na varredura (separados por vírgula)
IGNORE_DIRS=target,.git,node_modules,__pycache__,.venv,dist,build

# Tamanho de cada chunk em caracteres
CHUNK_SIZE=1500

# Sobreposição entre chunks consecutivos em caracteres
CHUNK_OVERLAP=200
